{%- if job.pahole %}

    - mkdir -p "{{ job.name}}"
    - pahole --sizes --class_name file://build/ipc-structs.txt build/src/xrt/targets/openxr/libopenxr_monado.so > "{{ job.name}}/ipc-sizes.txt"{% endif %}
{%- if not "ndk" in job.name %}

    - cd build && ctest --output-on-failure
